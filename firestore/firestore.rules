rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'superadmin';
    }

    function sameBusiness(businessId) {
      return isSignedIn() && userDoc().data.businessId == businessId;
    }

    function businessEnabled(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)).data.accessEnabled != false;
    }

    function sameOperationalBusiness(businessId) {
      return sameBusiness(businessId) && businessEnabled(businessId);
    }

    function isBackoffice(businessId) {
      return sameOperationalBusiness(businessId) && userRole() in ['admin', 'cashier'];
    }

    function isAdmin(businessId) {
      return sameOperationalBusiness(businessId) && userRole() == 'admin';
    }

    function isCashier(businessId) {
      return sameOperationalBusiness(businessId) && userRole() == 'cashier';
    }

    function isCourierOfOrder(resourceData) {
      return isSignedIn()
        && sameOperationalBusiness(resourceData.businessId)
        && userRole() == 'courier'
        && resourceData.assignedCourierId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create: if (isSignedIn() && request.auth.uid == userId) || isSuperAdmin();
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.businessId == resource.data.businessId;
      allow delete: if false;
    }

    match /businesses/{businessId} {
      allow read: if sameBusiness(businessId) || isSuperAdmin();
      allow write: if isSuperAdmin();

      match /settings/{settingId} {
        allow read: if sameOperationalBusiness(businessId) || isSuperAdmin();
        allow create, update: if isSuperAdmin() || isAdmin(businessId)
          || (isCashier(businessId) && settingId in ['posLedger', 'counters']);
        allow delete: if false;
      }

      match /customers/{customerId} {
        allow read: if sameOperationalBusiness(businessId) || isSuperAdmin();
        allow create, update: if isBackoffice(businessId) || isSuperAdmin();
        allow delete: if isAdmin(businessId) || isSuperAdmin();
      }

      match /couriers/{courierId} {
        allow read: if sameOperationalBusiness(businessId) || isSuperAdmin();
        allow create: if isAdmin(businessId) || isSuperAdmin();
        allow update: if isAdmin(businessId) || isSuperAdmin()
          || (
            sameOperationalBusiness(businessId)
            && userRole() == 'courier'
            && courierId == request.auth.uid
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastSeenAt', 'status'])
          );
        allow delete: if false;
      }

      match /deliveryOrders/{orderId} {
        allow read: if isBackoffice(businessId) || isCourierOfOrder(resource.data) || isSuperAdmin();
        allow create: if (isBackoffice(businessId) || isSuperAdmin())
          && request.resource.data.businessId == businessId;
        allow update: if isBackoffice(businessId) || isSuperAdmin()
          || (
            isCourierOfOrder(resource.data)
            && request.resource.data.businessId == resource.data.businessId
            && request.resource.data.customerId == resource.data.customerId
            && request.resource.data.customerName == resource.data.customerName
            && request.resource.data.customerPhone == resource.data.customerPhone
            && request.resource.data.address == resource.data.address
            && request.resource.data.items == resource.data.items
            && request.resource.data.subtotal == resource.data.subtotal
            && request.resource.data.deliveryFee == resource.data.deliveryFee
            && request.resource.data.total == resource.data.total
            && request.resource.data.paymentMethod == resource.data.paymentMethod
            && request.resource.data.assignedCourierId == resource.data.assignedCourierId
            && request.resource.data.assignedCourierName == resource.data.assignedCourierName
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.status in ['assigned', 'en_route', 'delivered', 'incident']
          );
        allow delete: if false;
      }

      match /liveTracking/{orderId} {
        allow read: if isBackoffice(businessId) || isSuperAdmin()
          || (
            isSignedIn()
            && exists(/databases/$(database)/documents/businesses/$(businessId)/deliveryOrders/$(orderId))
            && get(/databases/$(database)/documents/businesses/$(businessId)/deliveryOrders/$(orderId)).data.assignedCourierId == request.auth.uid
          );
        allow create, update: if isSignedIn()
          && sameOperationalBusiness(businessId)
          && userRole() == 'courier'
          && request.resource.data.courierId == request.auth.uid
          && request.resource.data.businessId == businessId;
        allow delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isBackoffice(businessId) || isSuperAdmin()
          || (sameOperationalBusiness(businessId) && resource.data.userId == request.auth.uid);
        allow create: if isBackoffice(businessId) || isSuperAdmin();
        allow update: if sameOperationalBusiness(businessId) && resource.data.userId == request.auth.uid;
        allow delete: if false;
      }
    }

    match /trackingSessions/{token} {
      allow get: if resource.data.active == true;
      allow list: if false;
      allow create, update: if (isSignedIn()
        && sameBusiness(request.resource.data.businessId)
        && userRole() in ['admin', 'cashier']) || (
          isSignedIn()
          && sameOperationalBusiness(request.resource.data.businessId)
          && userRole() == 'courier'
          && exists(/databases/$(database)/documents/businesses/$(request.resource.data.businessId)/deliveryOrders/$(request.resource.data.orderId))
          && get(/databases/$(database)/documents/businesses/$(request.resource.data.businessId)/deliveryOrders/$(request.resource.data.orderId)).data.assignedCourierId == request.auth.uid
        ) || isSuperAdmin();
      allow delete: if false;
    }
  }
}
